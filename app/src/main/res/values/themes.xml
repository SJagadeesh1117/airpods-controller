<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.AirPodsController" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:windowBackground">@color/bg</item>
        <item name="android:statusBarColor">@color/bg</item>
        <item name="android:navigationBarColor">@color/bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <style name="AncButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/text_muted</item>
        <item name="strokeColor">@color/divider</item>
        <item name="backgroundTint">@color/card_bg2</item>
        <item name="android:layout_marginEnd">4dp</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="FindButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:textColor">@color/accent</item>
        <item name="strokeColor">@color/accent</item>
        <item name="backgroundTint">@color/card_bg2</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>
